                  short-term crisis response.
                </p>
              </li>
            </ul>
          </div>
          <div>
            <h3>Affordable Everyday Living</h3>
          </div>
          <div>
            <h3>Public safety</h3>
          </div>
          <div>
            <h3>Transportation</h3>
          </div> -->
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
